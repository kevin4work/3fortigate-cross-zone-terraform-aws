# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version
# control as they are data points which are potentially sensitive and subject
# to change depending on the environment.
#
*.tfvars
*.tfplan
*.tfstate
*.tfstate.backup

# Ignore .terraform directory and all provider plugins
.terraform/

# Ignore lock file (generated)
.terraform.lock.hcl

# Ignore license files (sensitive)
*.lic
license*

# Ignore SSH keys
*.pem
*.key

# Ignore bootstrap configuration files that may contain sensitive data
# Uncomment if needed:
# fgtvm.conf

# Ignore IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore log files
*.log

# Ignore crash reports
.crash
